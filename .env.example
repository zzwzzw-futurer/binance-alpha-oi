TELEGRAM_BOT_TOKEN=123456789:replace_with_your_bot_token
TELEGRAM_CHAT_ID=replace_with_your_chat_id

# Every 5 minutes.
SCAN_INTERVAL_SECONDS=300

# Binance Alpha rank query. Empty ALPHA_CHAINS means all supported chains.
ALPHA_CHAINS=
ALPHA_PERIOD=20
ALPHA_PAGE_SIZE=200
ALPHA_MAX_PAGES=10

# Filters.
TOP10_THRESHOLD=80
FUTURES_QUOTE_ASSET=USDT
FUTURES_MINUTES=5
FUTURES_MINUTE_QUOTE_VOLUME=300000
FUTURES_REQUIRE_ALL_MINUTES=true

# Some Binance futures symbols represent token multiples, e.g. 1000TOKENUSDT.
FUTURES_SYMBOL_PREFIXES=,1000,10000,1000000,1M

# Avoid repeated Telegram alerts for the same token/futures pair.
ALERT_COOLDOWN_SECONDS=3600
SEND_EMPTY_RESULT=false

# Website sync. The monitor writes latest.json and history.json here every scan.
WEB_SYNC_ENABLED=true
WEB_OUTPUT_DIR=site/data
WEB_HISTORY_LIMIT=288

# Optional: commit site/data/*.json to GitHub after each scan.
# Use a fine-grained GitHub token with Contents read/write access to this repo.
GITHUB_SYNC_ENABLED=true
GITHUB_SYNC_TOKEN=
GITHUB_SYNC_REPOSITORY=zzwzzw-futurer/binance-alpha-oi
GITHUB_SYNC_BRANCH=main
GITHUB_SYNC_PATH_PREFIX=site/data
GITHUB_SYNC_COMMIT_MESSAGE=Update public scan data
GITHUB_SYNC_TIMEOUT=20
GITHUB_SYNC_RETRIES=2

# Optional: POST each scan payload to your website backend.
WEB_SYNC_WEBHOOK_URL=
WEB_SYNC_WEBHOOK_TOKEN=
WEB_SYNC_WEBHOOK_TIMEOUT=15

# Runtime.
MAX_WORKERS=8
LOG_LEVEL=INFO
STATE_FILE=.alpha_futures_monitor_state.json
